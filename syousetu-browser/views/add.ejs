<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>小説を登録</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<link rel="stylesheet" href="/style.css">
<body class="whole-add">
  <div class="title-login">
      <div class="site-title">マイノベルズ</div>
      <% if (username) { %>
        <div class="account-menu">
          <button type="button" class="account-button"><i class="fas fa-user"></i>  <%= username %> <i class="fas fa-chevron-down"></i></button>
          <div class="account-option">
              <div class="acc-user2"><%= username %></div>  
              <a href="/logout"><i class="fas fa-right-from-bracket"></i> ログアウト</a>
            </div>
        </div>
      <% } else { %>
        <a class="login-button" href="/login">ログイン</a>
      <% } %>
    </div>
    <nav class="add-top">
      <a href="/">ブックマーク</a>
      <i class="fas fa-chevron-right"></i>
      <span>小説を登録</span>
    </nav>

  <div class="add-body">
    <div class="add-top1">小説登録</div>

    <form action="/add" method="POST">
      <div class="add-title">
        <label>タイトル</label><br>
        <input type="text" name="title" required>
      </div>
      <div class="add-URL">
        <label>URL</label><br>
        <input type="url" name="url" required placeholder="https://">
      </div>
      <div class="add-rate">
          <label>評価</label><br>
          <select name="rating">
              <option value="1">★☆☆☆☆</option>
              <option value="2">★★☆☆☆</option>
              <option value="3">★★★☆☆</option>
              <option value="4">★★★★☆</option>
              <option value="5">★★★★★</option>
          </select>
      </div>
      <div class="add-stat">
          <label>ステータス</label><br>
          <select name="status">
              <option value="完結済">完結済</option>
              <option value="連載中">連載中</option>
          </select>
      </div>
      <div class="add-tag">
        <label>タグ（半角スペース区切り）</label><br>
        <input type="text" name="tags" placeholder="異世界 恋愛 コメディ">
      </div>
      <div class="add-gaiyou">
        <label>概要</label><br>
        <textarea name="summary"></textarea>
      </div>
      <div class="add-save">
        <a href="/">ブックマークTOPに戻る</a>
        <button type="submit">小説を登録[実行]</button>
      </div>
    </form>

  </div> 
</body>
</html>